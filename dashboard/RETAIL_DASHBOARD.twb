      <aliases enabled='yes' />
      <column caption='Age Groups' datatype='string' name='[Calculation_0150646542872576]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [age]&lt;=24 THEN &quot;18-24&quot;&#13;&#10;ELSEIF [age]&lt;=34 Then &quot;25-34&quot;&#13;&#10;ELSEIF [age]&lt;=44 THEN &quot;35-44&quot;&#13;&#10;ELSEIF [age]&lt;=54 THEN &quot;45-54&quot;&#13;&#10;ELSE &quot;55+&quot;&#13;&#10;END' />
      </column>
      <column caption='Total Revenue' datatype='real' default-format='C1033%' name='[Calculation_1026407475253248]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([price] * [quantity])' />
      </column>
      <column caption='Total Orders' datatype='integer' name='[Calculation_1026407475695617]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customer_id])' />
      </column>
      <column caption='Total Units Sold' datatype='integer' name='[Calculation_1026407476105218]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([quantity])' />
      </column>
      <column caption='Average Order Value' datatype='real' default-format='C1033%' name='[Calculation_1026407476232195]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1026407475253248]/[Calculation_1026407475695617]' />
      </column>
      <column caption='Average Customer Rating' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Calculation_1026407476457476]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([review_score])' />
      </column>
